# ─────────────────────────────────────────────────────────────────
# INTERNATIONAL JOURNAL OF TRANSDISCIPLINARY SCIENCE AND ENGINEERING BACKEND — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use Atlas URI for production
MONGODB_URI=mongodb://127.0.0.1:27017/ijtse

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_64_byte_hex_secret
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=ijtse_refresh_token

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=1

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=15

# Email (Free Service: Gmail App Password) — for contact form & submission notifications
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
ADMIN_NOTIFY_EMAIL=admin@ijtse.org

# Admin seed — used ONCE by: npm run seed:admin
SEED_ADMIN_EMAIL=admin@ijtse.org
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=IJTSE Administrator

# ─── Deployment (Render / Railway) ────────────────────────────────
# Set these as dashboard env vars — never hardcode in code:
#   MONGODB_URI  → Atlas connection string (mongodb+srv://...)
#   JWT_SECRET   → strong random secret
#   JWT_REFRESH_SECRET → strong random secret (different from JWT_SECRET)
#   CORS_ORIGIN  → comma-separated frontend domains (e.g. https://app.example.com,https://admin.example.com)
#   NODE_ENV     → production
# ─────────────────────────────────────────────────────────────────
